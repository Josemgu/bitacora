# Bitacora - Configuration
# Copy this file to .env and fill in your values

# Database — leave empty for SQLite (local), or set PostgreSQL URL for homelab
# DATABASE_URL=postgresql://bitacora:password@db:5432/bitacora

# AI Provider API Keys (set only the ones you use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# GitHub Personal Access Token (for repo management)
# GITHUB_TOKEN=ghp_...

# App settings
BITACORA_DB_PATH=./data/bitacora.db
TIMEZONE=America/Santo_Domingo
