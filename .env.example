# Bitacora - Configuration
# Copy this file to .env and fill in your values

# Database — leave empty for SQLite (local), or set PostgreSQL URL for homelab
# DATABASE_URL=postgresql://bitacora:password@db:5432/bitacora

# AI Provider API Keys (set only the ones you use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# GitHub Personal Access Token (for repo management)
# GITHUB_TOKEN=ghp_...

# App settings
BITACORA_DB_PATH=./data/bitacora.db
TIMEZONE=America/Santo_Domingo

# ─── Security (REQUIRED in production) ───
# Secret used to sign JWT tokens. Generate: python -c "import os;print(os.urandom(32).hex())"
# BITACORA_SECRET_KEY=change-me-to-a-long-random-value

# Key used to encrypt stored API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# BITACORA_FERNET_KEY=

# Enforce JWT authentication on protected/admin endpoints (default: false)
# BITACORA_AUTH_ENABLED=false

# Token lifetimes
# BITACORA_ACCESS_TOKEN_MINUTES=60
# BITACORA_REFRESH_TOKEN_DAYS=7

# Comma-separated list of allowed CORS origins (NEVER use "*")
# BITACORA_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate limits (slowapi syntax)
# BITACORA_RATE_LIMIT=120/minute
# BITACORA_RATE_LIMIT_AUTH=10/minute

# Environment: development | production
BITACORA_ENV=development
