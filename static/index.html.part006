              <div class="log-template">
                <div class="log-field"><span class="log-label">Aprendí</span><div class="log-line"></div></div>
                <div class="log-field"><span class="log-label">Construí</span><div class="log-line"></div></div>
                <div class="log-field"><span class="log-label">Problema encontrado</span><div class="log-line"></div></div>
                <div class="log-field"><span class="log-label">Cómo lo resolví</span><div class="log-line"></div></div>
                <div class="log-field"><span class="log-label">Nuevas palabras en inglés</span><div class="log-line"></div></div>
                <div class="log-field"><span class="log-label">Código subido</span><div class="log-line"></div></div>
              </div>
              <button class="btn btn-primary btn-block">Guardar entrada</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────── VISTA: MESA DE TRABAJO ─────── -->
    <section class="view" id="view-mesa">
      <div class="view-bar">
        <span class="crumb">mesa de trabajo</span>
        <span class="view-bar-meta">0 nodos · 0 conexiones</span>
      </div>

      <div class="view-body view-body-flush">
        <div class="mesa">
          <aside class="mesa-tools">
            <p class="tool-label">Nodos</p>
            <div class="tool-grid">
              <button class="tool" style="--accent:#3fb950"><span class="tool-ico">PC</span>PC</button>
              <button class="tool" style="--accent:#58a6ff"><span class="tool-ico">SRV</span>Servidor</button>
              <button class="tool" style="--accent:#a371f7"><span class="tool-ico">RTR</span>Router</button>
              <button class="tool" style="--accent:#d29922"><span class="tool-ico">SW</span>Switch</button>
              <button class="tool" style="--accent:#f85149"><span class="tool-ico">FW</span>Firewall</button>
              <button class="tool" style="--accent:#39c5cf"><span class="tool-ico">CLD</span>Nube</button>
              <button class="tool" style="--accent:#8b949e"><span class="tool-ico">DB</span>Base de datos</button>
              <button class="tool" style="--accent:#e6edf3"><span class="tool-ico">NET</span>Internet</button>
            </div>

            <p class="tool-label">Conexiones</p>
            <div class="tool-row">
              <button class="tool tool-wide"><span class="line-solid"></span>Flecha</button>
              <button class="tool tool-wide"><span class="line-dashed"></span>Línea</button>
            </div>

            <p class="tool-label">Plantillas</p>
            <div class="tool-col">
              <button class="btn btn-ghost btn-sm">LAN básica</button>
              <button class="btn btn-ghost btn-sm">DMZ + LAN</button>
              <button class="btn btn-ghost btn-sm">VPC Cloud</button>
            </div>

            <div class="tool-foot">
              <button class="btn btn-ghost btn-sm btn-block">Exportar JSON</button>
              <button class="btn btn-ghost btn-sm btn-block">Importar JSON</button>
            </div>
          </aside>

          <div class="mesa-canvas">
            <div class="canvas-bar">
              <div class="zoom">
                <button class="icon-btn">−</button>
                <span>100%</span>
                <button class="icon-btn">+</button>
              </div>
              <div class="legend">
                <span><i class="dot dot-green"></i>PC</span>
                <span><i class="dot dot-blue"></i>Servidor</span>
                <span><i class="dot dot-red"></i>Firewall</span>
                <span><i class="dot dot-cyan"></i>Nube</span>
              </div>
            </div>
            <div class="canvas">
              <div class="empty">
                <svg class="ico empty-ico"><use href="#i-mesa"></use></svg>
                <p>Elige una herramienta y haz clic en el lienzo para colocar tu primer nodo.</p>
                <span class="empty-hint">Doble clic renombra · Delete elimina · Arrastra para mover</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────── VISTA: CHAT IA ─────── -->
    <section class="view" id="view-chat">
      <div class="view-bar">
        <span class="crumb">chat ia</span>
        <span class="view-bar-meta">modelo: — · 0 mensajes</span>
      </div>

      <div class="view-body view-body-flush">
        <div class="chat">
          <aside class="chat-side">
            <div class="field">
              <label>PROVEEDOR</label>
              <div class="select">
                <select>
                  <option>OpenAI</option>
                  <option>Anthropic</option>
                  <option>Google</option>
                  <option>Ollama</option>
                  <option>Custom</option>
               