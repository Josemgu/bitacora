der="Tu apellido">
              </div>
            </div>
            <div class="field">
              <label>Meta final</label>
              <input type="text" id="profile-goal" class="input" placeholder="Ej: Cloud Security Engineer en Canada">
            </div>
            <div class="grid-3" style="margin-top:12px">
              <div class="field">
                <label>Idioma de la IA</label>
                <div class="select">
                  <select id="profile-language">
                    <option value="es">Espanol</option>
                    <option value="en">English</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
              <div class="field">
                <label>Nivel de experiencia</label>
                <div class="select">
                  <select id="profile-level">
                    <option value="principiante">Principiante</option>
                    <option value="intermedio" selected>Intermedio</option>
                    <option value="avanzado">Avanzado</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
              <div class="field">
                <label>Horas por semana</label>
                <input type="number" id="profile-weekly-hours" class="input" value="15" min="1" max="80">
              </div>
            </div>
            <div class="field" style="margin-top:12px">
              <label>Zona horaria</label>
              <div class="select">
                <select id="profile-timezone">
                  <option value="America/Santo_Domingo">Santo Domingo (GMT-4)</option>
                  <option value="America/New_York">New York (GMT-4/5)</option>
                  <option value="America/Toronto">Toronto (GMT-4/5)</option>
                  <option value="America/Mexico_City">Mexico City (GMT-6)</option>
                  <option value="America/Bogota">Bogota (GMT-5)</option>
                  <option value="America/Lima">Lima (GMT-5)</option>
                  <option value="America/Santiago">Santiago (GMT-4/3)</option>
                  <option value="Europe/Madrid">Madrid (GMT+1/2)</option>
                  <option value="UTC">UTC</option>
                </select>
                <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
              </div>
            </div>
            <div style="display:flex;gap:10px;margin-top:16px">
              <button class="btn btn-ghost" id="btn-cancel-profile">Cancelar</button>
              <button class="btn btn-primary" id="btn-save-profile">Guardar perfil</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────── VISTA: CONFIGURACIÓN ─────── -->
    <section class="view" id="view-config">
      <div class="view-bar">
        <span class="crumb">configuración</span>
        <span class="view-bar-meta">datos locales</span>
      </div>

      <div class="view-body">
        <div class="section-head">
          <h1>Configuración</h1>
          <p>Proveedores de IA y gestión de tus datos.</p>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2>Proveedores de IA</h2>
            <button class="btn btn-primary btn-sm"><svg class="ico"><use href="#i-agregar"></use></svg>Agregar</button>
          </div>
          <div class="panel-body">
            <div class="empty empty-sm">
              <svg class="ico empty-ico"><use href="#i-ia"></use></svg>
              <p>Todavía no hay proveedores configurados.</p>
              <span class="empty-hint">Agrega uno para habilitar el Chat IA</span>
            </div>
            <div class="tpl-row">
              <span class="tpl-label">Plantillas</span>
              <button class="chip chip-sm">OpenAI</button>
              <button class="chip chip-sm">Anthropic</button>
              <button class="chip chip-sm">Google</button>
              <button class="chip chip-sm">Ollama</button>
              <button class="chip chip-sm">Custom</button>
            </div>
          </div>
        </div>

        <div class="grid-2">
          <div class="panel">
            <div class="panel-head"><h2>Exportar datos</h2></div>
            <div class="panel-body">
              <p class="panel-note">Descarga un JSON con tu roadmap, recursos, horario y bitácora.</p>
              <button class="btn btn-ghost btn-block">Descargar JSON</button>
            </div>
          </div>
          <div class="panel">
            <div class="panel-head"><h2>Importar datos</h2></div>
            <div class="panel-body">
              <p class="panel-note">Pega un JSON o selecciona un archivo exportado.</p>
              <textarea class="input mono ta-sm" placeholder='{ "roadmap": … }'></textarea>
              <button class="btn btn-ghost btn-block">Importar</button>
            </div>
          </div>
        </div>

        <div class="panel panel-danger">
          <div class="panel-head"><h2>Zona de peligro</h2></div>
          <div class="panel-body">
            <div class="danger-row">
              <div>
                <strong>Eliminar todos los datos</strong>
                <p class="panel-note">Borra tu progreso, recursos, diagramas y bitácora. No se puede deshacer.</p>
              </div>
              <button class="btn btn-danger">Eliminar todo</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ VISTA: IMPORTAR ROADMAP ═══════ -->
    <section class="view" id="view-import">
      <div class="view-bar">
        <span class="crumb">importar roadmap</span>
        <span class="view-bar-meta">markdown · roadmap.sh · JSON</span>
      </div>
      <div class="view-body">
        <div class="section-head">
          <h1>Importar Roadmap</h1>
          <p>Trae roadmaps existentes o sube tu propio archivo.</p>
        </div>
        <div class="grid-2">
          <div class="panel">
            <div class="panel-head"><h2>Subir archivo Markdown</h2></div>
            <div class="panel-body">
              <p class="panel-note">Arrastra un archivo .md o seleccionalo. La estructura se interpreta automaticamente.</p>
              <div class="field">
                <label>Archivo</label>
                <input type="file" id="import-md-file" class="input" accept=".md,.markdown" style="padding:6px 10px">
              </div>
              <div class="field" style="margin-top:12px">
                <label>Nombre del roadmap</label>
                <input type="text" id="import-md-title" class="input" placeholder="Ej: Cloud Security Engineer">
              </div>
              <button class="btn btn-primary btn-block" id="btn-import-md" style="margin-top:14px">
                <svg class="ico"><use href="#i-agregar"></use></svg>Importar
              </button>
            </div>
          </div>
          <div class="panel">
            <div class="panel-head"><h2>Desde roadmap.sh</h2></div>
            <div class="panel-body">
              <p class="panel-note">Selecciona un roadmap oficial de roadmap.sh.</p>
              <div class="field">
                <label>Roadmap</label>
                <div class="select">
                  <select id="import-roadmapsh-select">
                    <option value="">Selecciona...</option>
                    <option value="devops">DevOps</option>
                    <option value="docker">Docker</option>
                    <option value="kubernetes">Kubernetes</option>
                    <option value="aws">AWS</option>
                    <option value="python">Python</option>
                    <option value="java">Java</option>
                    <option value="golang">Go</option>
                    <option value="frontend">Frontend</option>
                    <option value="backend">Backend</option>
                    <option value="full-stack">Full Stack</option>
                    <option value="ai-data-scientist">AI & Data Scientist</option>
                    <option value="cyber-security">Cyber Security</option>
                    <option value="blockchain">Blockchain</option>
                    <option value="postgresql">PostgreSQL</option>
                    <option value="redis">Redis</option>
                    <option value="software-architect">Software Architect</option>
                    <option value="ux-design">UX Design</option>
                    <option value="game-developer">Game Developer</option>
                    <option value="react">React</option>
                    <option value="vue">Vue</option>
                    <option value="angular">Angular</option>
                    <option value="nodejs">Node.js</option>
                    <option value="typescript">TypeScript</option>
                    <option value="linux">Linux</option>
                    <option value="nginx">Nginx</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
              <button class="btn btn-primary btn-block" id="btn-import-sh" style="margin-top:14px">
                <svg class="ico"><use href="#i-externo"></use></svg>Descargar e importar
              </button>
            </div>
          </div>
        </div>
        <div class="panel">
          <div class="panel-head"><h2>Preview</h2></div>
          <div class="panel-body" id="import-preview-area">
            <div class="empty">
              <svg class="ico empty-ico"><use href="#i-info"></use></svg>
              <p>Selecciona un archivo o un roadmap de la lista para ver el preview.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ VISTA: GENERAR ROADMAP CON IA ═══════ -->
    <section class="view" id="view-generate">
      <div class="view-bar">
        <span class="crumb">generar roadmap</span>
        <span class="view-bar-meta">IA powered</span>
      </div>
      <div class="view-body">
        <div class="hero">
          <p class="kicker">IA GENERATIVA</p>
          <h1>Crea un roadmap con <em>Inteligencia Artificial</em></h1>
          <p class="hero-sub">Describe lo que quieres aprender. La IA generara una estructura completa con temas, recursos y laboratorios.</p>
        </div>
        <div class="panel">
          <div class="panel-body">
            <div class="field">
              <label>Que quieres aprender?</label>
              <textarea id="generate-prompt" class="input mono ta-sm" placeholder="Ej: Quiero aprender Cloud Security para trabajar en AWS. Tengo experiencia en redes y Linux. Tengo 6 meses."></textarea>
            </div>
            <div class="grid-2" style="margin-top:12px;margin-bottom:0">
              <div class="field">
                <label>Nivel actual</label>
                <div class="select">
                  <select id="generate-level">
                    <option value="beginner">Principiante</option>
                    <option value="intermediate">Intermedio</option>
                    <option value="advanced">Avanzado</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
              <div class="field">
                <label>Duracion estimada</label>
                <div class="select">
                  <select id="generate-duration">
                    <option value="3">3 meses</option>
                    <option value="6">6 meses</option>
                    <option value="12" selected>12 meses</option>
                    <option value="24">24 meses</option>
                    <option value="36">36 meses</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
            </div>
            <button class="btn btn-primary btn-block" id="btn-generate-roadmap" style="margin-top:14px">
              <svg class="ico"><use href="#i-ia"></use></svg>Generar roadmap
            </button>
          </div>
        </div>
        <div class="panel" id="generate-result-panel" style="display:none">
          <div class="panel-head"><h2>Resultado</h2><span class="tag tag-green" id="generate-status-tag">Generando...</span></div>
          <div class="panel-body" id="generate-result-area"></div>
        </div>
      </div>
    </section>

    <!-- ═══════ VISTA: LABORATORIOS ═══════ -->
    <section class="view" id="view-labs">
      <div class="view-bar">
        <span class="crumb">laboratorios</span>
        <span class="view-bar-meta">plataformas interactivas</span>
      </div>
      <div class="view-body">
        <div class="section-head">
          <h1>Laboratorios</h1>
          <p>Practica en entornos reales. Selecciona una plataforma para ver los labs relacionados.</p>
        </div>
        <div class="filter-bar">
          <div class="search-field">
            <svg class="ico"><use href="#i-busqueda"></use></svg>
            <input type="text" id="labs-search" placeholder="Buscar laboratorios...">
          </div>
          <div class="chip-row" id="labs-platform-chips">
            <button class="chip chip-sm is-on" data-platform="all">Todos</button>
            <button class="chip chip-sm" data-platform="tryhackme">TryHackMe</button>
            <button class="chip chip-sm" data-platform="hackthebox">HackTheBox</button>
            <button class="chip chip-sm" data-platform="letsdefend">LetsDefend</button>
            <button class="chip chip-sm" data-platform="aws_skill_builder">AWS Skill Builder</button>
            <button class="chip chip-sm" data-platform="azure_learn">Azure Learn</button>
            <button class="chip chip-sm" data-platform="google_cloud_skills">Google Cloud Skills</button>
            <button class="chip chip-sm" data-platform="kodekloud">KodeKloud</button>
            <button class="chip chip-sm" data-platform="portswigger">PortSwigger</button>
            <button class="chip chip-sm" data-platform="overthewire">OverTheWire</button>
            <button class="chip chip-sm" data-platform="picoctf">PicoCTF</button>
            <button class="chip chip-sm" data-platform="other">Otros</button>
          </div>
        </div>
        <div class="res-grid" id="labs-grid"></div>
      </div>
    </section>

    <!-- ═══════ VISTA: CENTRO DE MENSAJES ═══════ -->
    <section class="view" id="view-messages">
      <div class="view-bar">
        <span class="crumb">centro de inteligencia</span>
        <span class="view-bar-meta">noticias · alertas · sugerencias</span>
      </div>
      <div class="view-body">
        <div class="section-head">
          <h1>Centro de Inteligencia</h1>
          <p>Todo lo que la IA y el sistema detectan para ti.</p>
        </div>
        <div class="filter-bar">
          <div class="chip-row" id="msg-category-chips">
            <button class="chip chip-sm is-on" data-cat="all">Todos</button>
            <button class="chip chip-sm" data-cat="news">Noticias</button>
            <button class="chip chip-sm" data-cat="resource">Recursos</button