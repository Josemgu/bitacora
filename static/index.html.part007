      </div>

      <div class="view-body">
        <div class="section-head">
          <h1>Panel de sistema</h1>
          <p>Estado de cada módulo de Bitácora.</p>
        </div>

        <div class="stat-row">
          <div class="stat"><span class="stat-value">0</span><span class="stat-label">Mensajes</span></div>
          <div class="stat"><span class="stat-value">0</span><span class="stat-label">Proveedores</span></div>
          <div class="stat"><span class="stat-value">14</span><span class="stat-label">KB almacenados</span></div>
          <div class="stat"><span class="stat-value">1.0.0</span><span class="stat-label">Versión</span></div>
        </div>

        <div class="mod-grid">
          <a class="mod" href="#roadmap">
            <div class="mod-head"><svg class="ico"><use href="#i-roadmap"></use></svg><i class="dot dot-green"></i></div>
