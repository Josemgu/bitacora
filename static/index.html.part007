            <em class="mod-state ok">Operativo</em>
          </a>
          <a class="mod" href="#horario">
            <div class="mod-head"><svg class="ico"><use href="#i-calendario"></use></svg><i class="dot dot-green"></i></div>
            <strong>Horario</strong><span>Rutina semanal activa</span>
            <em class="mod-state ok">Operativo</em>
          </a>
          <a class="mod" href="#mesa">
            <div class="mod-head"><svg class="ico"><use href="#i-mesa"></use></svg><i class="dot dot-green"></i></div>
            <strong>Mesa de trabajo</strong><span>3 plantillas disponibles</span>
            <em class="mod-state ok">Operativo</em>
          </a>
          <a class="mod" href="#chat">
            <div class="mod-head"><svg class="ico"><use href="#i-ia"></use></svg><i class="dot dot-yellow"></i></div>
            <strong>Chat IA</strong><span>Sin proveedor configurado</span>
            <em class="mod-state warn">Requiere configuración</em>
          </a>
          <a class="mod" href="#config">
            <div class="mod-head"><svg class="ico"><use href="#i-ajustes"></use></svg><i class="dot dot-green"></i></div>
            <strong>Configuración</strong><span>Datos locales</span>
            <em class="mod-state ok">Operativo</em>
          </a>
        </div>

        <div class="panel">
          <div class="panel-head"><h2>Actividad reciente</h2></div>
          <div class="panel-body">
            <ul class="activity">
              <li><i class="dot dot-green"></i><span>Tema completado — <strong>SSH solo por llave</strong></span><em>hace 2 h</em></li>
              <li><i class="dot dot-blue"></i><span>Recurso agregado — <strong>CIS Benchmarks Ubuntu</strong></span><em>hace 5 h</em></li>
              <li><i class="dot dot-yellow"></i><span>Entrada de bitácora — <strong>Semana 12</strong></span><em>ayer</em></li>
              <li><i class="dot dot-green"></i><span>Tema completado — <strong>CIS Benchmark aplicado</strong></span><em>hace 3 días</em></li>
              <li><i class="dot dot-purple"></i><span>Diagrama guardado — <strong>homelab-topologia-v2</strong></span><em>hace 4 días</em></li>
            </ul>
          </div>
        </div>

        <!-- Panel: Perfil de usuario -->
        <div class="panel" id="profile-panel">
          <div class="panel-head">
            <h2>Perfil de usuario</h2>
            <button class="btn btn-primary btn-sm" id="btn-edit-profile">Editar</button>
          </div>
          <div class="panel-body" id="profile-display">
            <!-- Se rellena dinámicamente -->
          </div>
          <div class="panel-body" id="profile-form" style="display:none">
            <!-- Formulario de edición -->
            <div class="grid-2">
              <div class="field">
                <label>Nombre</label>
                <input type="text" id="profile-first-name" class="input" placeholder="Tu nombre">
              </div>
              <div class="field">
                <label>Apellido</label>
                <input type="text" id="profile-last-name" class="input" placeholder="Tu apellido">
              </div>
            </div>
            <div class="field">
              <label>Meta final</label>
              <input type="text" id="profile-goal" class="input" placeholder="Ej: Cloud Security Engineer en Canada">
            </div>
            <div class="grid-3" style="margin-top:12px">
              <div class="field">
                <label>Idioma de la IA</label>
                <div class="select">
                  <select id="profile-language">
                    <option value="es">Espanol</option>
                    <option value="en">English</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
              <div class="field">
                <label>Nivel de experiencia</label>
                <div class="select">
                  <select id="profile-level">
                    <option value="principiante">Principiante</option>
                    <option value="intermedio" selected>Intermedio</option>
                    <option value="avanzado">Avanzado</option>
                  </select>
                  <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
                </div>
              </div>
              <div class="field">
                <label>Horas por semana</label>
                <input type="number" id="profile-weekly-hours" class="input" value="15" min="1" max="80">
              </div>
            </div>
            <div class="field" style="margin-top:12px">
              <label>Zona horaria</label>
              <div class="select">
                <select id="profile-timezone">
                  <option value="America/Santo_Domingo">Santo Domingo (GMT-4)</option>
                  <option value="America/New_York">New York (GMT-4/5)</option>
                  <option value="America/Toronto">Toronto (GMT-4/5)</option>
                  <option value="America/Mexico_City">Mexico City (GMT-6)</option>
                  <option value="America/Bogota">Bogota (GMT-5)</option>
                  <option value="America/Lima">Lima (GMT-5)</option>
                  <option value="America/Santiago">Santiago (GMT-4/3)</option>
                  <option value="Europe/Madrid">Madrid (GMT+1/2)</option>
                  <option value="UTC">UTC</option>
                </select>
                <svg class="ico rot-270"><use href="#i-chevron"></use></svg>
              </div>
            </div>
            <div style="display:flex;gap:10px;margin-top:16px">
              <button class="btn btn-ghost" id="btn-cancel-profile">Cancelar</button>
              <button class="btn btn-primary" id="btn-save-profile">Guardar perfil</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────── VISTA: CONFIGURACIÓN ─────── -->
    <section class="view" id="view-config">
      <div class="view-bar">
        <span class="crumb">configuración</span>
        <span class="view-bar-meta">datos locales</span>
      </div>

      <div class="view-body">
        <div class="section-head">
          <h1>Configuración</h1>
          <p>Proveedores de IA y gestión de tus datos.</p>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2>Proveedores de IA</h2>
            <button class="btn btn-primary btn-sm"><svg class="ico"><use href="#i-agregar"></use></svg>Agregar</button>
          </div>
          <div class="panel-body">
            <div class="empty empty-sm">
              <svg class="ico empty-ico"><use href="#i-ia"></use></svg>
              <p>Todavía no hay proveedores configurados.</p>
              <span class="empty-hint">Agrega uno para habilitar el Chat IA</span>
            </div>
            <div class="tpl-row">
              <span class="tpl-label">Plantillas</span>
              <button class="chip chip-sm">OpenAI</button>
              <button class="chip chip-sm">Anthropic</button>
              <button class="chip chip-sm">Google</button>
              <button class="chip chip-sm">Ollama</button>
              <button class="chip chip-sm">Custom</button>
            </div>
          </div>
        </div>

        <div class="grid-2">
          <div class="panel">
            <div class="panel-head"><h2>Exportar datos</h2></div>
            <div class="panel-body">
              <p class="panel-note">Descarga un JSON con tu roadmap, recursos, horario y bitácora.</p>
              <button class="btn btn-ghost btn-block">Descargar JSON</button>
            </div>
          </div>
          <div class="panel">
            <div class="panel-head"><h2>Importar datos</h2></div>
            <div class="panel-body">
              <p class="panel-note">Pega un JSON o selecciona un archivo exportado.</p>
              <textarea class="input mono ta-sm" placeholder='{ "roadmap": … }'></textarea>
              <button class="btn btn-ghost btn-block">Importar</button>
            </div>
          </div>
        </div>

        <div class="panel panel-danger">
          <div class="panel-head"><h2>Zona de peligro</h2></div>
          <div class="panel-body">
            <div class="danger-row">
              <div>
                <strong>Eliminar todos los datos</strong>
                <p class="panel-note">Borra tu progreso, recursos, diagramas y bitácora. No se puede deshacer.</p>
              </div>
              <button class="btn btn-danger">Eliminar todo</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ VISTA: IMPORTAR ROADMAP ═══════ -->
    <section class="view" id="view-import">
      <div class="view-bar">
        <span class="crumb">importar roadmap</span>
        <span class="view-bar-meta">markdown · roadmap.sh · JSON</span>
      </div>
      <div class="view-body">
        <div class="section-head">
          <h1>Importar Roadmap</h1>
          <p>Trae roadmaps existentes o sube tu propio archivo.</p>
        </div>
        <div class="grid-2">
          <div class="panel">
            <div class="panel-head"><h2>Subir archivo Markdown</h2></div>
            <div class="panel-body">
              <p class="panel-note">Arrastra un archivo .md o seleccionalo. La estructura se interpreta automaticamente.</p>
              <div class="field">
                <label>Archivo</label>
                <input type="file" id="import-md-file" class="input" accept=".md,.markdown" style="padding:6px 10px">
              </div>
              <div class="field" style="margin-top:12px">
                <label>Nombre del roadmap</label>
                <input type="text" id="import-md-title" class="input" placeholder="Ej: Cloud Security Engineer">
              </div>
              <button class="btn btn-primary btn-block" id="btn-import-md" style="margin-top:14px">
                <svg class="ico"><use href="#i-agregar"></use></svg>Importar
              </button>
            </div>
          </div>
          <div class="panel">
            <div class="panel-head"><h2>Desde roadmap.sh</h2></div>
            <div class="panel-body">
              <p class="panel-note">Selecciona un roadmap oficial de roadmap.sh.</p>
              <div class="field">
                <label>Roadmap</label>
                <div class="select">
                  <select id="import-roadmapsh-select">
                    <option value="">Selecciona...</option>
                    <option value="devops">DevOps</option>
                    <option value="docker">Docker</option>
                    <option value="kubernetes">Kubernetes</option>
                    <o