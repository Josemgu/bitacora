# Bitacora - Git Ignore

# Environment variables
.env

# Database
*.db
*.sqlite
*.sqlite3

# Uploads
data/uploads/*
!data/uploads/.gitkeep

# Exports
data/exports/*
!data/exports/.gitkeep

# Logs
data/logs/*
!data/logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
